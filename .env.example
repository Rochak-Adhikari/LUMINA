# Google Gemini API Key (REQUIRED)
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Debug Audio Logs (OPTIONAL)
# Set to 1 to enable verbose VAD and audio debug logs
# Default: 0 (quiet)
# DEBUG_AUDIO=0

# Tool Clamp (Phase B.2 safety gate)
# LUMINA_TOOL_CLAMP_MODE: "on" (default) | "off"
#   "on"  = force all tool permissions False, except allowlisted tools
#   "off" = use saved settings as-is (no forced overrides)
# LUMINA_TOOL_CLAMP_ALLOW: comma-separated tool names to keep enabled when clamp is ON
#   Example: "browser_control" or "browser_control,read_file"
#   Default: "" (nothing allowed — original Phase B.2 behavior)
LUMINA_TOOL_CLAMP_MODE=on
LUMINA_TOOL_CLAMP_ALLOW=browser_control,local_browser_control

# Browser Agent Settings (OPTIONAL — Phase T1, headless)
# BROWSER_HEADLESS=true
# BROWSER_SLOWMO_MS=0
# BROWSER_DEFAULT_TIMEOUT_MS=15000

# ========================================
# Local Brave Browser Control (Phase T2)
# ========================================
# Controls the user's REAL Brave window via Chrome DevTools Protocol (CDP).
# Brave is launched with --remote-debugging-port so Lumina can attach.
#
# LOCAL_BROWSER: which browser to control (only "brave" supported for now)
LOCAL_BROWSER=brave
# BRAVE_EXECUTABLE_PATH: full path to brave.exe (auto-detected on Windows if omitted)
# BRAVE_EXECUTABLE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
# BRAVE_USER_DATA_DIR: Brave profile storage root (auto-detected on Windows if omitted)
# BRAVE_USER_DATA_DIR=C:\Users\<USER>\AppData\Local\BraveSoftware\Brave-Browser\User Data
# BRAVE_PROFILE_DIR: which profile sub-folder to use
BRAVE_PROFILE_DIR=Default
# BRAVE_REMOTE_DEBUGGING_PORT: CDP port
BRAVE_REMOTE_DEBUGGING_PORT=9222
# LOCAL_BROWSER_AUTOSTART: if true, Lumina starts Brave automatically when needed
LOCAL_BROWSER_AUTOSTART=true
